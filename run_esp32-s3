#!/usr/bin/env bash
# nubjuk-mcu serial monitor — opens a new Terminal.app window.
# Usage: ./run_esp32-s3 [PORT]
#   default PORT = /dev/cu.usbserial-0001
# Exit (in the new window): Ctrl+]

set -euo pipefail

PORT="${1:-/dev/cu.usbserial-0001}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# 새 Terminal 윈도우에서 실행될 한 줄. \$HOME 는 새 셸에서 expand.
CMD="cd '$SCRIPT_DIR' && source \$HOME/esp/esp-idf/export.sh && exec idf.py -p '$PORT' monitor"

osascript <<APPLESCRIPT
tell application "Terminal"
    activate
    do script "$CMD"
end tell
APPLESCRIPT
